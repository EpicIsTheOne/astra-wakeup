<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#88000000">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_margin="12dp"
        android:background="#0B1020"
        android:elevation="14dp"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Astra"
                    android:textColor="#F8FAFC"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Bottom panel prototype — proper activity, not cursed overlay permission nonsense."
                    android:textColor="#C4B5FD"
                    android:textSize="12sp" />
            </LinearLayout>

            <Button
                android:id="@+id/btnOverlayClose"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="#334155"
                android:text="Close"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvOverlayStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="#1E1B4B"
            android:paddingLeft="10dp"
            android:paddingTop="6dp"
            android:paddingRight="10dp"
            android:paddingBottom="6dp"
            android:text="Opening voice input…"
            android:textColor="#DDD6FE"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvOverlayTranscript"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:minHeight="44dp"
            android:background="#111827"
            android:padding="12dp"
            android:text="Waiting to hear you…"
            android:textColor="#E5E7EB"
            android:textSize="14sp" />

        <ScrollView
            android:id="@+id/scrollOverlayConversation"
            android:layout_width="match_parent"
            android:layout_height="260dp"
            android:layout_marginTop="10dp"
            android:background="#111827"
            android:fillViewport="true"
            android:padding="14dp">

            <TextView
                android:id="@+id/tvOverlayConversation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#E5E7EB"
                android:textSize="15sp" />
        </ScrollView>

        <EditText
            android:id="@+id/etOverlayInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="#1F2937"
            android:hint="Type to Astra if speech flakes out. Because Android loves drama."
            android:imeOptions="actionSend"
            android:inputType="textCapSentences|textMultiLine"
            android:maxLines="4"
            android:minLines="1"
            android:padding="12dp"
            android:textColor="#F9FAFB"
            android:textColorHint="#9CA3AF" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnOverlaySend"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:backgroundTint="#EC4899"
                android:text="Send"
                android:textColor="#FFFFFF" />

            <Space
                android:layout_width="8dp"
                android:layout_height="1dp" />

            <Button
                android:id="@+id/btnOverlayListen"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:backgroundTint="#8B5CF6"
                android:text="Listen"
                android:textColor="#FFFFFF" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
