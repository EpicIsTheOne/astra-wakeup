<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Task Editor"
        android:textSize="22sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/etTaskId"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Task ID" />

    <EditText
        android:id="@+id/etTaskDesc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Description" />

    <Spinner
        android:id="@+id/spTaskTrigger"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:entries="@array/context_triggers" />

    <EditText
        android:id="@+id/etTaskSpeech"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Speech text step" />

    <EditText
        android:id="@+id/etTaskNotify"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Notification text step (optional)" />

    <Spinner
        android:id="@+id/spTaskPersonality"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:entries="@array/personality_modes" />

    <EditText
        android:id="@+id/etDelaySpeechMs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Speech delay ms (optional)"
        android:inputType="number" />

    <EditText
        android:id="@+id/etDelayNotifyMs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Notify delay ms (optional)"
        android:inputType="number" />

    <EditText
        android:id="@+id/etDelayPersonaMs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Personality delay ms (optional)"
        android:inputType="number" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnLoadTask"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Load" />

        <Button
            android:id="@+id/btnDeleteTask"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Delete" />

        <Button
            android:id="@+id/btnSaveTask"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Save" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvTasks"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text=""
        android:textSize="13sp" />
</LinearLayout>
