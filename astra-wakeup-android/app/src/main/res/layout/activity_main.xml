<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#0F172A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Astra"
            android:textColor="#F8FAFC"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvVersion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="version: -"
            android:textColor="#94A3B8"
            android:textSize="12sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Connect this phone, tune wake behavior, and open chat — without the clutter."
            android:textColor="#CBD5E1"
            android:textSize="15sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="#162033"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Connect this phone"
                android:textColor="#F8FAFC"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvConnectHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Use your OpenClaw URL and shared gateway token to unlock chat and wake controls."
                android:textColor="#CBD5E1"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/etApiUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="#0B1220"
                android:hint="OpenClaw URL"
                android:padding="12dp"
                android:singleLine="true"
                android:text="http://72.60.29.204:18789"
                android:textColor="#F8FAFC"
                android:textColorHint="#64748B" />

            <EditText
                android:id="@+id/etGatewayToken"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="#0B1220"
                android:hint="Gateway shared token"
                android:inputType="textPassword"
                android:padding="12dp"
                android:singleLine="true"
                android:textColor="#F8FAFC"
                android:textColorHint="#64748B" />

            <Button
                android:id="@+id/btnConnectGateway"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:backgroundTint="#EC4899"
                android:text="Connect this phone"
                android:textColor="#FFFFFF" />

            <TextView
                android:id="@+id/tvConnectBanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="#1E293B"
                android:padding="14dp"
                android:text=""
                android:textColor="#E2E8F0"
                android:textSize="14sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvApiStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="This phone is not connected yet"
                android:textColor="#F8FAFC"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvApiDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Enter your OpenClaw URL and shared gateway token, then tap Connect this phone."
                android:textColor="#CBD5E1"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnToggleAdvancedGateway"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:backgroundTint="#334155"
                android:text="Show advanced gateway options"
                android:textColor="#E2E8F0" />

            <LinearLayout
                android:id="@+id/layoutGatewayAdvanced"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="vertical"
                android:visibility="gone">

                <EditText
                    android:id="@+id/etBootstrapToken"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:background="#0B1220"
                    android:hint="Bootstrap token (experimental/fallback)"
                    android:inputType="textPassword"
                    android:padding="12dp"
                    android:singleLine="true"
                    android:textColor="#F8FAFC"
                    android:textColorHint="#64748B" />

                <Button
                    android:id="@+id/btnSave"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:backgroundTint="#475569"
                    android:text="Save advanced settings"
                    android:textColor="#FFFFFF" />

                <TextView
                    android:id="@+id/tvHealthChip"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Gateway status: -"
                    android:textColor="#CBD5E1"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvLineChip"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Connection state: -"
                    android:textColor="#CBD5E1"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvChatChip"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Chat state: -"
                    android:textColor="#CBD5E1"
                    android:textSize="12sp" />

                <LinearLayout
                    android:id="@+id/layoutGatewayDebug"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvNodeIdentity"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="nodeId=-"
                        android:textColor="#C4B5FD"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvGatewayDebug"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="gateway debug: -"
                        android:textColor="#94A3B8"
                        android:textSize="12sp" />

                    <Button
                        android:id="@+id/btnProbeGateway"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:backgroundTint="#334155"
                        android:text="Probe gateway auth"
                        android:textColor="#E2E8F0" />

                    <Button
                        android:id="@+id/btnClearDeviceToken"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:backgroundTint="#334155"
                        android:text="Clear device token"
                        android:textColor="#E2E8F0" />

                    <Button
                        android:id="@+id/btnClearGatewayAuth"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:backgroundTint="#7F1D1D"
                        android:text="Clear all gateway auth"
                        android:textColor="#FFFFFF" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutWakeCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="#162033"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Wake controls"
                android:textColor="#F8FAFC"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvWakeHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Connect this phone to enable wake controls."
                android:textColor="#CBD5E1"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvWakeTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Wake time: 5:50 AM (America/New_York)"
                android:textColor="#FDE68A"
                android:textSize="15sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnPickWakeTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:backgroundTint="#D946EF"
                android:text="Change wake time"
                android:textColor="#FFFFFF" />

            <CheckBox
                android:id="@+id/cbPunish"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Keep pushing until I tap I'm awake"
                android:textColor="#E2E8F0" />

            <Button
                android:id="@+id/btnSchedule"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:backgroundTint="#8B5CF6"
                android:text="Schedule 5:50 AM wake"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/btnTest"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:backgroundTint="#475569"
                android:text="Test wake screen"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutChatCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="#162033"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chat"
                android:textColor="#F8FAFC"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvChatHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Connect this phone first, then open your Astra chat."
                android:textColor="#CBD5E1"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnOpenChat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:backgroundTint="#334155"
                android:text="Open Chat"
                android:textColor="#FFFFFF" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
