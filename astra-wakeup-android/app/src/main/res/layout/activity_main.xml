<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#0F172A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Astra"
            android:textColor="#F8FAFC"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvVersion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="version: -"
            android:textColor="#94A3B8"
            android:textSize="12sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Wake-up control, chat, and OpenClaw pairing — minus the clutter."
            android:textColor="#CBD5E1"
            android:textSize="15sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="#162033"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Connect this phone"
                android:textColor="#F8FAFC"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvConnectHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Tap Connect. If approval is needed, ask Astra to approve the pending Android pairing request."
                android:textColor="#CBD5E1"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/etApiUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="#0B1220"
                android:hint="OpenClaw URL"
                android:padding="12dp"
                android:singleLine="true"
                android:text="http://72.60.29.204:8787/api/astra"
                android:textColor="#F8FAFC"
                android:textColorHint="#64748B" />

            <Button
                android:id="@+id/btnConnectGateway"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:backgroundTint="#EC4899"
                android:text="Connect this phone"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/btnToggleAdvancedGateway"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:backgroundTint="#334155"
                android:text="Show advanced gateway options"
                android:textColor="#E2E8F0" />

            <LinearLayout
                android:id="@+id/layoutGatewayAdvanced"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <EditText
                    android:id="@+id/etGatewayToken"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="#0B1220"
                    android:hint="Gateway shared token (optional)"
                    android:inputType="textPassword"
                    android:padding="12dp"
                    android:singleLine="true"
                    android:textColor="#F8FAFC"
                    android:textColorHint="#64748B" />

                <EditText
                    android:id="@+id/etBootstrapToken"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="#0B1220"
                    android:hint="Gateway bootstrap token (optional)"
                    android:inputType="textPassword"
                    android:padding="12dp"
                    android:singleLine="true"
                    android:textColor="#F8FAFC"
                    android:textColorHint="#64748B" />

                <Button
                    android:id="@+id/btnSave"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:backgroundTint="#475569"
                    android:text="Save advanced settings"
                    android:textColor="#FFFFFF" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvApiStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Status: not connected"
                android:textColor="#F8FAFC"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvApiDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text=""
                android:textColor="#CBD5E1"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvConnectBanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="#3F1D3B"
                android:padding="12dp"
                android:text=""
                android:textColor="#FCE7F3"
                android:textSize="13sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvHealthChip"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="health: -"
                    android:textColor="#CBD5E1"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvLineChip"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="line: -"
                    android:textColor="#CBD5E1"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvChatChip"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="chat: -"
                    android:textColor="#CBD5E1"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutGatewayDebug"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvGatewayDebug"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="gateway debug: -"
                    android:textColor="#94A3B8"
                    android:textSize="12sp" />

                <Button
                    android:id="@+id/btnProbeGateway"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:backgroundTint="#334155"
                    android:text="Probe gateway auth"
                    android:textColor="#E2E8F0" />

                <Button
                    android:id="@+id/btnClearDeviceToken"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:backgroundTint="#334155"
                    android:text="Clear device token"
                    android:textColor="#E2E8F0" />

                <Button
                    android:id="@+id/btnClearGatewayAuth"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:backgroundTint="#7F1D1D"
                    android:text="Clear all gateway auth"
                    android:textColor="#FFFFFF" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="#162033"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Wake controls"
                android:textColor="#F8FAFC"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Wake profile"
                android:textColor="#CBD5E1"
                android:textSize="13sp" />

            <Spinner
                android:id="@+id/spWakeProfile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:entries="@array/wake_profiles" />

            <CheckBox
                android:id="@+id/cbRandomSfx"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Random annoying SFX"
                android:textColor="#E2E8F0" />

            <CheckBox
                android:id="@+id/cbPunish"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Punishment mode"
                android:textColor="#E2E8F0" />

            <CheckBox
                android:id="@+id/cbAstraFm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Astra FM mode"
                android:textColor="#E2E8F0" />

            <Button
                android:id="@+id/btnSchedule"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:backgroundTint="#8B5CF6"
                android:text="Schedule 5:50 AM wake"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/btnTest"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:backgroundTint="#475569"
                android:text="Test wake screen"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="#162033"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chat"
                android:textColor="#F8FAFC"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Chat unlocks after this phone finishes connecting to OpenClaw."
                android:textColor="#CBD5E1"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnOpenChat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:backgroundTint="#334155"
                android:text="Open Chat"
                android:textColor="#FFFFFF" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
