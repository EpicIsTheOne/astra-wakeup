<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Astra"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Astra app: Wake-Up + Chat tabs."
        android:textSize="16sp" />

    <Button
        android:id="@+id/btnOpenChat"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Open Chat" />

    <Button
        android:id="@+id/btnOpenMemory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Memory Manager" />

    <Button
        android:id="@+id/btnOpenCalendar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Calendar / Cron" />

    <Button
        android:id="@+id/btnOpenAnalytics"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Wake Analytics" />

    <Button
        android:id="@+id/btnReleaseNotes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Release Notes" />

    <TextView
        android:id="@+id/tvVersion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="version: -"
        android:textSize="12sp" />

    <EditText
        android:id="@+id/etApiUrl"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="OpenClaw Astra API URL"
        android:singleLine="true"
        android:text="http://72.60.29.204:8787/api/astra" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Wake profile" />

    <Spinner
        android:id="@+id/spWakeProfile"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:entries="@array/wake_profiles" />

    <CheckBox
        android:id="@+id/cbRandomSfx"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Enable random annoying SFX" />

    <CheckBox
        android:id="@+id/cbPunish"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enable punishment mode" />

    <Button
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Save settings" />

    <Button
        android:id="@+id/btnCheckApi"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Check server connection" />

    <TextView
        android:id="@+id/tvApiStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="API status: unknown"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tvApiDetails"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="12sp" />

    <TextView
        android:id="@+id/tvHealthChip"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="health: -"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/tvLineChip"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="line: -"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/tvChatChip"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="chat: -"
        android:textSize="12sp" />

    <Button
        android:id="@+id/btnSchedule"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Schedule 5:50 AM" />

    <Button
        android:id="@+id/btnTest"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Test wake screen" />
</LinearLayout>
