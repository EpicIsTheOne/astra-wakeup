<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Astra Memory"
        android:textSize="22sp"
        android:textStyle="bold" />

    <Spinner
        android:id="@+id/spMemoryCategory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:entries="@array/memory_categories" />

    <Spinner
        android:id="@+id/spMemoryAddCategory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:entries="@array/memory_categories_add" />

    <EditText
        android:id="@+id/etMemoryNote"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="Add a memory note..." />

    <Button
        android:id="@+id/btnAddMemory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Add Memory Note" />

    <TextView
        android:id="@+id/tvMemory"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="10dp"
        android:text="Loading..."
        android:textSize="14sp" />

    <Button
        android:id="@+id/btnRefreshMemory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Refresh" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <EditText
            android:id="@+id/etDeleteIndex"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Delete # (from list)"
            android:inputType="number" />

        <Button
            android:id="@+id/btnDeleteIndex"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Delete" />
    </LinearLayout>

    <Button
        android:id="@+id/btnClearMemory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Clear All Memory" />
</LinearLayout>
