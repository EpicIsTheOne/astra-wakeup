<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent">

    <LinearLayout
        android:id="@+id/overlayPanelCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginStart="8dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_astra_panel"
        android:clipToOutline="true"
        android:elevation="18dp"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="12dp"
        android:paddingEnd="18dp"
        android:paddingBottom="18dp">

        <FrameLayout
            android:id="@+id/viewOverlayDragHandleTouchTarget"
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:layout_gravity="center_horizontal"
            android:foreground="?android:attr/selectableItemBackgroundBorderless">

            <View
                android:id="@+id/viewOverlayDragHandle"
                android:layout_width="42dp"
                android:layout_height="5dp"
                android:layout_gravity="center"
                android:background="#475569" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:id="@+id/viewOverlayOrb"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:background="@drawable/bg_astra_orb" />

            <LinearLayout
                android:id="@+id/layoutWaveform"
                android:layout_width="wrap_content"
                android:layout_height="20dp"
                android:layout_marginStart="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <View
                    android:id="@+id/viewWave1"
                    android:layout_width="4dp"
                    android:layout_height="8dp"
                    android:background="#C4B5FD" />

                <Space
                    android:layout_width="3dp"
                    android:layout_height="1dp" />

                <View
                    android:id="@+id/viewWave2"
                    android:layout_width="4dp"
                    android:layout_height="14dp"
                    android:background="#DDD6FE" />

                <Space
                    android:layout_width="3dp"
                    android:layout_height="1dp" />

                <View
                    android:id="@+id/viewWave3"
                    android:layout_width="4dp"
                    android:layout_height="10dp"
                    android:background="#C4B5FD" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvOverlayStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_astra_chip"
                android:paddingLeft="12dp"
                android:paddingTop="7dp"
                android:paddingRight="12dp"
                android:paddingBottom="7dp"
                android:text="Opening voice input…"
                android:textColor="#DDD6FE"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvOverlayConnectionBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="#3F1D2E"
            android:padding="12dp"
            android:text="Panel test mode"
            android:textColor="#FBCFE8"
            android:textSize="13sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvOverlayTranscript"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:minHeight="52dp"
            android:background="@drawable/bg_astra_surface"
            android:ellipsize="end"
            android:maxLines="8"
            android:padding="14dp"
            android:text=""
            android:textColor="#E5E7EB"
            android:textSize="15sp"
            android:visibility="gone" />

        <EditText
            android:id="@+id/etOverlayInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_astra_input"
            android:hint="Ask Astra anything…"
            android:imeOptions="actionSend"
            android:inputType="textCapSentences|textMultiLine"
            android:maxLines="4"
            android:minLines="1"
            android:padding="14dp"
            android:textColor="#F9FAFB"
            android:textColorHint="#9CA3AF" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnOverlaySend"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:backgroundTint="#EC4899"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minHeight="0dp"
                android:text="Send"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />

            <Space
                android:layout_width="8dp"
                android:layout_height="1dp" />

            <Button
                android:id="@+id/btnOverlayListen"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:backgroundTint="#8B5CF6"
                android:text="Listen"
                android:textColor="#FFFFFF" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
